<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/etDisplayName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nom affiché" />

        <Spinner
            android:id="@+id/spLocale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mode sombre" />

            <Switch
                android:id="@+id/swNightMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <EditText
            android:id="@+id/etSecret"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Token (chiffré uniquement)"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/btnPersistSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sauvegarder prefs" />

        <Button
            android:id="@+id/btnFetchSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Charger prefs" />

        <Button
            android:id="@+id/btnPersistJson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sauvegarder fichier JSON" />

        <Button
            android:id="@+id/btnFetchJson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Charger fichier JSON" />

        <Button
            android:id="@+id/btnWipeAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Effacer" />

        <TextView
            android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>